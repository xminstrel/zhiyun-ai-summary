# 服务监听地址
HOST=127.0.0.1
PORT=8787

# 默认使用哪个供应商。可选：deepseek, openai, qwen, doubao, kimi, custom
AI_PROVIDER=deepseek

# 控制哪些供应商出现在网页/油猴面板里，顺序就是下拉框顺序
AI_PROVIDERS=deepseek,openai,qwen,doubao,kimi,custom

# 没有 API Key 时可设为 true，用于验证油猴脚本、服务端和页面流程
AI_MOCK=false

# 全局长文本和超时配置
MAX_CHUNK_CHARS=12000
MAX_OUTPUT_TOKENS=5000
AI_TIMEOUT_MS=300000
SAVE_OUTPUTS=true

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_ENDPOINT_MODE=chat-completions
DEEPSEEK_OUTPUT_TOKEN_PARAM=max_tokens

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5
OPENAI_ENDPOINT_MODE=responses
OPENAI_OUTPUT_TOKEN_PARAM=max_completion_tokens

# 通义千问 OpenAI 兼容模式
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_ENDPOINT_MODE=chat-completions
QWEN_OUTPUT_TOKEN_PARAM=max_tokens

# 豆包/火山方舟 OpenAI 兼容模式
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-1-6
DOUBAO_ENDPOINT_MODE=chat-completions
DOUBAO_OUTPUT_TOKEN_PARAM=max_tokens

# Kimi/Moonshot
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_ENDPOINT_MODE=chat-completions
KIMI_OUTPUT_TOKEN_PARAM=max_tokens

# 自定义 OpenAI 兼容接口
CUSTOM_LABEL=自定义兼容接口
CUSTOM_API_KEY=
CUSTOM_BASE_URL=https://example.com/v1
CUSTOM_MODEL=custom-model
CUSTOM_ENDPOINT_MODE=chat-completions
CUSTOM_OUTPUT_TOKEN_PARAM=max_tokens
